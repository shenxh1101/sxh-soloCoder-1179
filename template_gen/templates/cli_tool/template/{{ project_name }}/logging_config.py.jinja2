{% if use_logging %}
import logging
import sys


def setup_logging(level: str = "{{ log_level }}") -> None:
    fmt = "%(asctime)s [%(levelname)s] %(name)s: %(message)s"
    logging.basicConfig(
        level=getattr(logging, level.upper(), logging.INFO),
        format=fmt,
        stream=sys.stderr,
    )
{% endif %}