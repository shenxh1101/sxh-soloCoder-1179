[build-system]
requires = ["setuptools>=61.0"]
build-backend = "setuptools.backends._legacy:_Backend"

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ description | default('A CLI tool') }}"
authors = [{name = "{{ author }}"}]
readme = "README.md"
requires-python = ">={{ python_version }}"
dependencies = [
{% if cli_framework == 'click' %}
    "click>=8.0",
{% elif cli_framework == 'typer' %}
    "typer>=0.9",
{% endif %}
    "pyyaml>=6.0",
]

[project.scripts]
{{ project_name }} = "{{ project_name }}.cli:main"