{% if use_tests %}
import subprocess
import sys


def test_cli_help():
    result = subprocess.run(
        [sys.executable, "-m", "{{ project_name }}.cli", "--help"],
        capture_output=True,
        text=True,
    )
    assert result.returncode == 0


def test_cli_hello():
    result = subprocess.run(
        [sys.executable, "-m", "{{ project_name }}.cli", "hello"],
        capture_output=True,
        text=True,
    )
    assert result.returncode == 0
{% endif %}